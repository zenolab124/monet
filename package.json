{
  "name": "cc-space-tauri",
  "version": "2.4.0",
  "description": "CC Space — Claude Code session viewer",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "pnpm mcp:build && pnpm dev",
    "build": "vue-tsc --noEmit && vite build",
    "build:full": "pnpm mcp:build:release && pnpm build",
    "mcp:build": "cargo build --bin cc-space-mcp --manifest-path src-tauri/Cargo.toml",
    "mcp:build:release": "cargo build --release --bin cc-space-mcp --manifest-path src-tauri/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.18.2",
  "devDependencies": {
    "@iconify-json/carbon": "^1.2.20",
    "@tauri-apps/cli": "^2.10.1",
    "@types/markdown-it": "^14.1.2",
    "@unocss/preset-icons": "^66.6.8",
    "@unocss/preset-wind4": "^66.6.8",
    "@unocss/transformer-directives": "^66.6.8",
    "@unocss/transformer-variant-group": "^66.6.8",
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^6.0.2",
    "unocss": "^66.6.8",
    "vite": "^8.0.8",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6"
  },
  "dependencies": {
    "@dnd-kit/helpers": "^0.5.0",
    "@dnd-kit/vue": "^0.5.0",
    "@shikijs/markdown-it": "^4.0.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "gridstack": "^12.6.0",
    "markdown-it": "^14.1.1",
    "shiki": "^4.0.2",
    "vue-i18n": "^11.4.5"
  }
}
