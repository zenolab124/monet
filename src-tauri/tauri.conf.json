{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Monet",
  "version": "0.1.9",
  "identifier": "io.github.zenolab124.monet",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev:full",
    "beforeBuildCommand": "pnpm build:full"
  },
  "app": {
    "windows": [
      {
        "title": "Monet",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "zoomHotkeysEnabled": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDdCOEVFNkYyMDkzNjI3QzIKUldUQ0p6WUo4dWFPZTN2dUtyMW9uUG55U0wyeFFwaWhlYllOa2RaR3lQYnNEZWtEYWI3S0l2UVQK",
      "endpoints": [
        "https://github.com/zenolab124/cc-space/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "infoPlist": "Info.plist",
      "dmg": {
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 },
        "windowSize": { "width": 660, "height": 400 }
      }
    }
  }
}
