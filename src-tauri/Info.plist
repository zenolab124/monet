<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSLocalNetworkUsageDescription</key>
	<string>CC Space needs local network access for network diagnostics and connecting to local development servers.</string>

	<key>NSAppleEventsUsageDescription</key>
	<string>CC Space uses AppleScript to open Terminal for resuming sessions and to manage scheduled-task wake and sleep.</string>

	<key>NSBonjourServices</key>
	<array>
		<string>_ccspace._tcp</string>
	</array>

	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>

	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>CC Space</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>ccspace</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
